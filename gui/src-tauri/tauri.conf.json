{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Firma CR",
  "version": "0.0.1",
  "identifier": "cr.libre.firma-cr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Firma CR — firmador",
        "width": 760,
        "height": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "firma-cr-pkcs11"
        ]
      }
    }
  }
}
