{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Firma CR",
  "version": "0.0.1",
  "identifier": "cr.libre.firma-cr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Firma CR — firmador",
        "width": 760,
        "height": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; worker-src 'self' blob:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:41231; object-src 'none'; base-uri 'self'; form-action 'none'; frame-src blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "recommends": [
          "firma-cr-pkcs11",
          "pcscd"
        ]
      }
    }
  }
}
